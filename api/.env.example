# --- runtime ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- database ---
# Local dev (docker-compose default)
DATABASE_URL=postgresql://turki:turki@localhost:5432/turki?schema=public

# --- auth (admin-only) ---
# Generate strong values for production. JWT_SECRET must be 32+ chars.
JWT_SECRET=replace-me-with-32-plus-random-chars-aaaaaaaaaaaaa
JWT_EXPIRES_IN=12h
COOKIE_SECRET=replace-me-with-cookie-secret-32-chars

# Seeded on first boot (only if no admin exists yet)
ADMIN_EMAIL=admin@turki.local
ADMIN_PASSWORD=ChangeMeOnFirstBoot!

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- public site ---
PUBLIC_SITE_URL=http://localhost:5173

# --- email (lead notifications) ---
# Optional. If unset, lead notifications are skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
LEAD_NOTIFY_TO=
